# Required
PVE_HOST=pve.example.com
PVE_NODE=pve
PVE_TOKEN_ID=root@pam!cofoundry
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SSH_TARGET=root@pve.example.com

# Optional — defaults shown, only set if you need to override
# PVE_PORT=8006
# PVE_DUMP_DIR=/var/lib/vz/dump
# CF_STORAGE=local
# CF_ISO_STORAGE=local
# CF_BRIDGE=vmbr0          # bridge for cloud-image builds (DHCP via guest agent)
# CF_BUILD_BRIDGE=vmbr1    # NAT bridge for ISO-installer + Windows builds
# CF_OUT_DIR=./dist        # leave blank to skip syncing artifacts back locally

# DNS resolver used by ISO-installer build VMs (IP/gateway are auto-allocated
# from the vmbr1 NAT pool per-build).
# CF_BUILD_DNS=1.1.1.1

# Optional CDN/R2 upload. Placeholders: {{file}} (local path), {{filename}} (name-arch-sha256.vma.zst), {{name}}, {{arch}}, {{sha256}}.
# CF_UPLOAD_CMD=aws s3 cp --endpoint-url https://<id>.r2.cloudflarestorage.com {{file}} s3://my-bucket/templates/{{filename}}
# CF_PUBLIC_URL_TMPL=https://images.cdn.example.com/templates/{{filename}}
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
