# .env — secrets and per-machine coordinates for `cf`. Gitignored.
#
# Non-secret deployment config (ports, storage, bridges, upload layout) lives in
# the committed cofoundry.toml, NOT here. This file holds only:
#   1. secrets — never committed anywhere
#   2. the coordinates cofoundry.toml references via ${VAR}
#
# Prefer cofoundry.local.toml (also gitignored) for non-secret per-machine
# overrides; keep this file for credentials. Run `cf config` to see what's
# resolved and where each value comes from.

# ── secrets ────────────────────────────────────────────────────────────────
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional — only if uploading artifacts to R2/S3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── coordinates referenced by ${VAR} in cofoundry.toml ───────────────────────
# (You can instead inline these in cofoundry.local.toml.)
PVE_HOST=pve.example.com
SSH_TARGET=root@pve.example.com
PVE_NODE=pve
PVE_TOKEN_ID=root@pam!cofoundry

# Only if uploading to R2 (endpoint carries the account id, so keep it here):
# R2_ENDPOINT=https://<id>.r2.cloudflarestorage.com
# R2_BUCKET=my-bucket
