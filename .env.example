# Required
PVE_HOST=pve.example.com
PVE_NODE=pve
PVE_TOKEN_ID=root@pam!cofoundry
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SSH_TARGET=root@pve.example.com

# Optional — defaults shown, only set if you need to override
# PVE_PORT=8006
# PVE_DUMP_DIR=/var/lib/vz/dump
# CF_STORAGE=local
# CF_ISO_STORAGE=local
# CF_BRIDGE=vmbr0          # bridge for cloud-image builds (DHCP via guest agent)
# CF_BUILD_BRIDGE=vmbr1    # NAT bridge for ISO-installer + Windows builds
# CF_OUT_DIR=./dist        # leave blank to skip syncing artifacts back locally

# DNS resolver used by ISO-installer build VMs (IP/gateway are auto-allocated
# from the vmbr1 NAT pool per-build).
# CF_BUILD_DNS=1.1.1.1

# Optional CDN/R2 upload.
#
# Placeholders (both CMDs and CF_PUBLIC_URL_TMPL):
#   {{file}}     local path to the artifact or sidecar
#   {{name}}     bare recipe name (e.g. almalinux-10)
#   {{arch}}     e.g. amd64
#   {{group}}    OS group (e.g. almalinux, debian, windows)
#   {{sha256}}   sha256 of the .vma.zst
#   {{filename}} content-addressed upload basename (name-arch-sha256.vma.zst / .json)
#
# IMPORTANT: `cf prune --r2` groups artifacts by their parent directory and
# keeps the newest N per directory, so each template MUST live in its own
# prefix. Upload .vma.zst and its .json sidecar as siblings at the same prefix.
#
# Both of these layouts are prune-compatible:
#   templates/{{name}}-{{arch}}/{{sha256}}.vma.zst              (flat — used by CI)
#   templates/{{group}}/{{name}}-{{arch}}/{{sha256}}.vma.zst   (OS-grouped)
# A flat `templates/{{filename}}` layout will NOT prune correctly.
#
# Without CF_SIDECAR_UPLOAD_CMD, sidecars never reach R2 and `cf publish --r2`
# can't see those templates (registry.json will be missing them).
#
# Set R2_ENDPOINT and R2_BUCKET once — the upload commands reference them as
# shell vars (`$R2_ENDPOINT`, `$R2_BUCKET`), and `cf prune --r2` / `cf publish
# --r2` read them directly. Single source of truth.
# R2_ENDPOINT=https://<id>.r2.cloudflarestorage.com
# R2_BUCKET=my-bucket
# R2_PREFIX=/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
# CF_UPLOAD_CMD='aws --endpoint-url $R2_ENDPOINT s3 cp {{file}} s3://$R2_BUCKET/templates/{{name}}-{{arch}}/{{sha256}}.vma.zst'
# CF_SIDECAR_UPLOAD_CMD='aws --endpoint-url $R2_ENDPOINT s3 cp {{file}} s3://$R2_BUCKET/templates/{{name}}-{{arch}}/{{sha256}}.json'
# CF_PUBLIC_URL_TMPL=https://images.cdn.example.com/templates/{{name}}-{{arch}}/{{sha256}}.vma.zst
