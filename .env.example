# Required
PVE_HOST=pve.example.com
PVE_NODE=pve
PVE_TOKEN_ID=root@pam!cofoundry
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SSH_TARGET=root@pve.example.com

# Optional — defaults shown, only set if you need to override
# PVE_PORT=8006
# PVE_DUMP_DIR=/var/lib/vz/dump
# CF_STORAGE=local
# CF_ISO_STORAGE=local
# CF_BRIDGE=vmbr0
# CF_WIN_BRIDGE=vmbr1
# CF_OUT_DIR=./out

# Required for Debian netinstall builds (debian-*). Not needed for any other recipe.
# CF_BUILD_IP=192.168.1.250   # a free IP on your vmbr0 subnet
# CF_BUILD_GW=192.168.1.1     # your Proxmox node's vmbr0 IP
# CF_BUILD_DNS=1.1.1.1

# Optional CDN integration. {{file}} and {{name}} placeholders.
# CF_UPLOAD_CMD=aws s3 cp {{file}} s3://my-bucket/templates/{{name}}.vma.zst
# CF_PUBLIC_URL_TMPL=https://images.cdn.example.com/templates/{{name}}.vma.zst
