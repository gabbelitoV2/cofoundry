{
  "name": "coport",
  "version": "1.2.0",
  "description": "Install Cofoundry VM templates into Proxmox",
  "type": "module",
  "scripts": {
    "build": "bun build --compile --target=bun-linux-x64 --outfile ../dist/coport src/main.ts",
    "build:mac": "bun build --compile --outfile ../dist/coport src/main.ts",
    "dev": "bun run src/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cofoundry/ui": "workspace:*",
    "commander": "^12",
    "consola": "^3",
    "picocolors": "^1",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  }
}
