{
  "name": "cofoundry",
  "version": "0.0.1",
  "description": "Automated Proxmox VM template builder. Produces vzdump (.vma.zst) artifacts from unattended ISO installations.",
  "type": "module",
  "module": "src/cli.ts",
  "bin": {
    "cf": "src/cli.ts"
  },
  "workspaces": [
    "coport",
    "packages/*"
  ],
  "scripts": {
    "cf": "bun run src/cli.ts",
    "build": "bun build --compile --target=bun-linux-x64 --outfile dist/cf src/cli.ts",
    "build:mac": "bun build --compile --outfile dist/cf src/cli.ts",
    "build:coport": "bun run --cwd coport build",
    "build:all": "bun run build && bun run build:coport",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@cofoundry/ui": "workspace:*",
    "@inquirer/prompts": "^8.5.0",
    "byte-size": "^9.0.1",
    "cli-spinners": "^3.4.0",
    "cli-truncate": "^6.0.0",
    "commander": "^12.1.0",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "figures": "^6.1.0",
    "log-update": "^8.0.0",
    "p-queue": "^9.3.0",
    "p-retry": "^8.0.0",
    "picocolors": "^1.1.1",
    "pretty-ms": "^9.3.0",
    "smol-toml": "^1.3.1",
    "ssh2": "^1.16.0",
    "ssh2-sftp-client": "^12.1.1",
    "tar": "^7.5.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ssh2": "^1.15.1",
    "@types/ssh2-sftp-client": "^9.0.6",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3"
  }
}
