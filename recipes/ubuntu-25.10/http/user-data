#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  network:
    version: 2
    ethernets:
      id0:
        match:
          name: "en*"
        addresses:
          - __PACKER_BUILD_IP__/24
        routes:
          - to: default
            via: __PACKER_BUILD_GW__
        nameservers:
          addresses:
            - __PACKER_BUILD_DNS__
  ssh:
    install-server: true
    allow-pw: true
    disable_root: false
    authorized-keys:
      - __PACKER_SSH_PUBLIC_KEY__
  packages:
    - qemu-guest-agent
  storage:
    layout:
      name: direct
    swap:
      size: 0
  late-commands:
    - curtin in-target -- bash -c "echo 'GRUB_CMDLINE_LINUX=\"console=tty0 console=ttyS0,115200\"' > /etc/default/grub.d/50-cofoundry.cfg"
    - curtin in-target -- update-grub
    - curtin in-target -- bash -c "mkdir -p /etc/ssh/sshd_config.d && printf 'PermitRootLogin yes\\nPasswordAuthentication yes\\n' > /etc/ssh/sshd_config.d/10-cofoundry.conf"
  user-data:
    package_upgrade: false
    users:
      - name: packer
        groups: [adm, sudo]
        lock-passwd: true
        sudo: ALL=(ALL) NOPASSWD:ALL
        shell: /bin/bash
        ssh_authorized_keys:
          - __PACKER_SSH_PUBLIC_KEY__
